# ============================================================
# AgriConnection Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in the values

# ============================================================
# Authentication & Database
# ============================================================
AUTH_SECRET=your_auth_secret_key_here_min_32_chars
AUTH_URL=http://localhost:3000
DATABASE_URL=postgresql://user:password@localhost:5432/agriconnection

# ============================================================
# Supabase
# ============================================================
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# ============================================================
# Email Service (Resend)
# ============================================================
RESEND_API_KEY=re_your_resend_api_key_here

# ============================================================
# Payment - M-Pesa
# ============================================================
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_PASSKEY=your_mpesa_passkey
MPESA_SHORTCODE=your_mpesa_shortcode
MPESA_TIMESTAMP=your_mpesa_timestamp

# ============================================================
# Payment - Stripe (optional)
# ============================================================
STRIPE_SECRET_KEY=sk_live_your_stripe_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key

# ============================================================
# Google Maps
# ============================================================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ============================================================
# Upload - Uploadcare
# ============================================================
EXPO_PUBLIC_UPLOADCARE_PUBLIC_KEY=your_uploadcare_public_key

# ============================================================
# AI - Gemini / Claude API Keys
# ============================================================
GEMINI_API_KEY=your_gemini_api_key
CLAUDE_API_KEY=your_claude_api_key

# ============================================================
# Mobile App Configuration
# ============================================================
EXPO_PUBLIC_CREATE_ENV=PRODUCTION
EXPO_PUBLIC_PROJECT_GROUP_ID=agriconnection
EXPO_PUBLIC_BASE_URL=https://agriconnection.api.example.com
EXPO_PUBLIC_PROXY_BASE_URL=https://proxy.agriconnection.example.com
EXPO_PUBLIC_HOST=agriconnection.example.com
EXPO_PUBLIC_ANALYTICS_ENDPOINT=https://analytics.agriconnection.example.com

# ============================================================
# Revenue Cat (In-App Purchases)
# ============================================================
EXPO_PUBLIC_REVENUE_CAT_TEST_STORE_API_KEY=your_test_api_key
EXPO_PUBLIC_REVENUE_CAT_APP_STORE_API_KEY=your_app_store_api_key
